{
  "rewrites": [
    {
      "source": "/studio/:path*",
      "destination": "/studio"
    },
    {
      "source": "/jeestarterkit/(.*)",
      "destination": "/jeestarterkit/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/reminders/cron?secret=my-secret-abc123-xyz",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/fetch-news?secret=edunext-news-cron-2026",
      "schedule": "30 1 * * *"
    }
  ]
}
