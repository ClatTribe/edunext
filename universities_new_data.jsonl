ary based on420Reviews", "headers": ["Scholarship", "Eligibility Criteria", "Amount of Scholarship"], "rows": [["Institute Merit-cum-Means Scholarship", "Family income of not more than INR ,50,000", "67% of the fees are exempted. 25% of the students can avail this. Renewal is done only for students having a minimum of 5 GPA every semester."], ["Institute free studentship", "Family income of not more than INR 4,50,000", "67% of the fees are exempted. 25% of the students can avail this. Renewal is done only for students having a minimum of 5 GPA every semester."], ["Institute Notional Prize", "Family income of not more than INR 4,50,000 and based on student\u2019s ranking in JEE", "Only 7% of the students receive this scholarship. The one-time grant is INR 1000."], ["Institute SC/ST Scholarship", "Family income of not more than INR 4,50,000", "Free mess and pocket money of INR 250 is provided to the students over and above tuition fee exemption. Renewal is done only for students having a minimum of 5 GPA every semester."]]}]}
